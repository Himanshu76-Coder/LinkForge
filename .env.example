# ==========================================
# LinkForge - Environment Variables Template
# ==========================================
# Copy this file to .env and fill in your actual values.
# Never commit the actual .env file to version control.

# ==========================================
# Database Configuration
# ==========================================
DB_URL=jdbc:mysql://localhost:3306/linkforge_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ==========================================
# JWT Configuration
# ==========================================
# Must be at least 256 bits (32+ characters). Change this in production.
JWT_SECRET=your-minimum-256-bit-secret-key-change-this-in-production

# ==========================================
# Application Configuration
# ==========================================
# Base URL used to construct short links in responses
APP_BASE_URL=http://localhost:8080
