# ==========================================
# LinkForge - Local Configuration Template
# ==========================================

# This file documents all the values you need to run LinkForge locally.
# The actual configuration lives in application-dev.properties, which is git-ignored and never committed to version control.
#
# To get started:
#   1. Fill in your local values in src/main/resources/application-dev.properties
#   2. For production, set these as real environment variables on your server
#      and reference them in application-prod.properties as ${VARIABLE_NAME}



# ==========================================
# Database Configuration
# ==========================================
DB_URL=jdbc:mysql://localhost:3306/linkforge_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password



# ==========================================
# JWT Configuration
# ==========================================
# Must be at least 256 bits (32+ characters). Use a strong random value in production.
JWT_SECRET=your-minimum-256-bit-secret-key-change-this-in-production



# ==========================================
# Application Configuration
# ==========================================
# Base URL used to construct short links in responses
APP_BASE_URL=http://localhost:8080

